rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // USERS COLLECTION
    // Users can read any user's public profile data
    // Users can only write their own user data
    match /users/{userId} {
      // Anyone can read user profiles (public data)
      // This includes: displayName, username, photoURL, subscription, settings, socialConnections
      allow read: if true;
      
      // Only the authenticated user can create/update their own profile
      allow create: if isAuthenticated();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // PROFILES COLLECTION
    // Public profile data that can be viewed by anyone
    // Only owner can modify their profile
    match /profiles/{profileId} {
      // Anyone can read published profiles
      allow read: if resource.data.isPublished == true || isOwner(profileId);
      
      // Only authenticated users can create profiles
      allow create: if isAuthenticated();
      
      // Only the profile owner can update
      allow update: if isOwner(profileId);
      allow delete: if isOwner(profileId);
    }
    
    // LINKS COLLECTION
    // Links belong to users
    match /links/{linkId} {
      // Links are only readable by the owner
      allow read: if isOwner(resource.data.userId);
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // ANALYTICS COLLECTION
    // Analytics data is private to the owner
    match /analytics/{analyticsId} {
      allow read, write: if isOwner(analyticsId);
    }
    
    // NOTIFICATIONS COLLECTION
    // Notifications are private to the recipient
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
